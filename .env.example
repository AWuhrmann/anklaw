# Copy to .env and fill in your API key(s).
# Never commit .env to version control.

# Required for Anthropic/Claude:
ANTHROPIC_API_KEY=sk-ant-...

# Required for OpenAI (if llm_provider = "openai"):
# OPENAI_API_KEY=sk-...

# Optional: override config file path
# ANKI_AGENT_CONFIG=/path/to/config.yaml
